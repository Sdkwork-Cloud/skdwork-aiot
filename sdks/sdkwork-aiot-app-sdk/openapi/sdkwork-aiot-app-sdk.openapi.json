{
  "openapi": "3.1.2",
  "info": {
    "title": "SDKWork AIoT App API",
    "version": "0.1.0",
    "description": "SDKWork AIoT app API contract. OpenAPI is the source of truth for generated app SDKs."
  },
  "servers": [
    {
      "url": "/app/v3/api/iot"
    }
  ],
  "tags": [
    {
      "name": "iot",
      "description": "User-facing AIoT device control and state APIs."
    }
  ],
  "paths": {
    "/app/v3/api/iot/devices": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "devices.list",
        "x-sdkwork-owner": "sdkwork-aiot",
        "x-sdkwork-api-authority": "sdkwork-aiot-app-api",
        "x-sdkwork-required-permission": "iot.devices.read",
        "summary": "List user-visible AIoT devices",
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Device collection.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotDeviceListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/app/v3/api/iot/devices/{deviceId}": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "devices.retrieve",
        "x-sdkwork-owner": "sdkwork-aiot",
        "x-sdkwork-api-authority": "sdkwork-aiot-app-api",
        "x-sdkwork-required-permission": "iot.devices.read",
        "summary": "Retrieve one AIoT device",
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DeviceId"
          }
        ],
        "responses": {
          "200": {
            "description": "Device resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotDeviceResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/app/v3/api/iot/devices/{deviceId}/commands": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "post": {
        "tags": ["iot"],
        "operationId": "devices.commands.create",
        "x-sdkwork-owner": "sdkwork-aiot",
        "x-sdkwork-api-authority": "sdkwork-aiot-app-api",
        "x-sdkwork-required-permission": "iot.commands.execute",
        "summary": "Create a device command",
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DeviceId"
          },
          {
            "$ref": "#/components/parameters/IdempotencyKey"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AiotCommandCreateRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Command accepted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotCommandResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/app/v3/api/iot/devices/{deviceId}/twin": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "devices.twin.retrieve",
        "x-sdkwork-owner": "sdkwork-aiot",
        "x-sdkwork-api-authority": "sdkwork-aiot-app-api",
        "x-sdkwork-required-permission": "iot.twins.read",
        "summary": "Retrieve device twin",
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DeviceId"
          }
        ],
        "responses": {
          "200": {
            "description": "Twin resource.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotTwinResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    },
    "/app/v3/api/iot/devices/{deviceId}/events": {
      "parameters": [
        {
          "$ref": "#/components/parameters/SdkworkTenantId"
        },
        {
          "$ref": "#/components/parameters/SdkworkOrganizationId"
        },
        {
          "$ref": "#/components/parameters/SdkworkUserId"
        },
        {
          "$ref": "#/components/parameters/SdkworkDataScope"
        },
        {
          "$ref": "#/components/parameters/SdkworkPermissionScope"
        }
      ],
      "get": {
        "tags": ["iot"],
        "operationId": "devices.events.list",
        "x-sdkwork-owner": "sdkwork-aiot",
        "x-sdkwork-api-authority": "sdkwork-aiot-app-api",
        "x-sdkwork-required-permission": "iot.devices.read",
        "summary": "List device events",
        "security": [
          {
            "AuthToken": [],
            "AccessToken": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/DeviceId"
          }
        ],
        "responses": {
          "200": {
            "description": "Device events.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AiotEventListResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Problem"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "AuthToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Authorization: Bearer <auth_token>"
      },
      "AccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token",
        "description": "SDKWork canonical access token header."
      }
    },
    "parameters": {
      "SdkworkTenantId": {
        "name": "X-Sdkwork-Tenant-Id",
        "in": "header",
        "required": true,
        "description": "Resolved tenant id provided by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      },
      "SdkworkOrganizationId": {
        "name": "X-Sdkwork-Organization-Id",
        "in": "header",
        "required": true,
        "description": "Resolved organization id provided by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      },
      "SdkworkUserId": {
        "name": "X-Sdkwork-User-Id",
        "in": "header",
        "required": false,
        "description": "Optional resolved user id provided by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      },
      "SdkworkDataScope": {
        "name": "X-Sdkwork-Data-Scope",
        "in": "header",
        "required": false,
        "description": "Optional resolved SDKWork data-scope integer.",
        "schema": {
          "type": "string",
          "pattern": "^-?[0-9]+$"
        }
      },
      "SdkworkPermissionScope": {
        "name": "X-Sdkwork-Permission-Scope",
        "in": "header",
        "required": true,
        "description": "Comma-separated permissions resolved by sdkwork-appbase IAM context.",
        "schema": {
          "type": "string",
          "minLength": 1
        }
      },
      "DeviceId": {
        "name": "deviceId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      },
      "IdempotencyKey": {
        "name": "Idempotency-Key",
        "in": "header",
        "required": false,
        "schema": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "responses": {
      "Problem": {
        "description": "Problem details.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      }
    },
    "schemas": {
      "AiotDevice": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "tenantId",
          "organizationId",
          "deviceId",
          "displayName",
          "productId",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable int64 identifier serialized as a string."
          },
          "tenantId": {
            "type": "string"
          },
          "organizationId": {
            "type": "string"
          },
          "deviceId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "productId": {
            "type": "string",
            "description": "Product int64 identifier serialized as a string."
          },
          "clientId": {
            "type": "string"
          },
          "chipFamily": {
            "type": "string"
          },
          "avatar": {
            "$ref": "#/components/schemas/MediaResource"
          },
          "status": {
            "type": "string"
          },
          "metadata": {
            "$ref": "#/components/schemas/JsonValue"
          },
          "lastSeenAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MediaKind": {
        "type": "string",
        "enum": ["image", "video", "audio", "voice", "document", "archive", "model", "other"]
      },
      "MediaSource": {
        "type": "string",
        "enum": ["object_storage", "external_url", "data_url", "provider_asset", "generated"]
      },
      "MediaChecksum": {
        "type": "object",
        "additionalProperties": false,
        "required": ["algorithm", "value"],
        "properties": {
          "algorithm": {
            "type": "string",
            "enum": ["sha256", "md5", "etag"]
          },
          "value": {
            "type": "string"
          }
        }
      },
      "MediaAccess": {
        "type": "object",
        "additionalProperties": false,
        "required": ["visibility"],
        "properties": {
          "visibility": {
            "type": "string",
            "enum": ["private", "tenant", "organization", "public", "signed"]
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MediaAiProvenance": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provenance": {
            "type": "string",
            "enum": ["uploaded", "generated", "edited", "imported"]
          },
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "promptId": {
            "type": "string"
          },
          "generationTaskId": {
            "type": "string"
          },
          "sourceMediaIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "seed": {
            "type": "string"
          },
          "moderationStatus": {
            "type": "string",
            "enum": ["unknown", "pending", "approved", "rejected", "blocked"]
          },
          "safetyLabels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "MediaResource": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "source"],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "$ref": "#/components/schemas/MediaKind"
          },
          "source": {
            "$ref": "#/components/schemas/MediaSource"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "publicUrl": {
            "type": "string",
            "format": "uri"
          },
          "uri": {
            "type": "string"
          },
          "objectBlobId": {
            "type": "string"
          },
          "bucketId": {
            "type": "string"
          },
          "objectKey": {
            "type": "string"
          },
          "objectVersion": {
            "type": "string"
          },
          "fileName": {
            "type": "string",
            "maxLength": 512
          },
          "mimeType": {
            "type": "string",
            "maxLength": 256
          },
          "sizeBytes": {
            "type": "string",
            "pattern": "^[0-9]+$"
          },
          "checksum": {
            "$ref": "#/components/schemas/MediaChecksum"
          },
          "width": {
            "type": "integer",
            "minimum": 0
          },
          "height": {
            "type": "integer",
            "minimum": 0
          },
          "durationSeconds": {
            "type": "number",
            "minimum": 0
          },
          "altText": {
            "type": "string",
            "maxLength": 512
          },
          "title": {
            "type": "string",
            "maxLength": 255
          },
          "access": {
            "$ref": "#/components/schemas/MediaAccess"
          },
          "ai": {
            "$ref": "#/components/schemas/MediaAiProvenance"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "AiotDeviceListResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotDevice"
            }
          }
        }
      },
      "AiotDeviceResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/AiotDevice"
          }
        }
      },
      "AiotCommandCreateRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capabilityName", "commandName", "payload"],
        "properties": {
          "capabilityName": {
            "type": "string",
            "maxLength": 128
          },
          "commandName": {
            "type": "string",
            "maxLength": 128
          },
          "payload": {
            "$ref": "#/components/schemas/JsonValue"
          },
          "requestMediaResourceId": {
            "type": "string"
          },
          "requestObjectBlobId": {
            "type": "string"
          },
          "requestMedia": {
            "$ref": "#/components/schemas/MediaResource"
          },
          "sessionId": {
            "type": "string",
            "maxLength": 128
          },
          "traceId": {
            "type": "string",
            "maxLength": 128
          },
          "timeoutAt": {
            "type": "string",
            "format": "date-time"
          },
          "idempotencyKey": {
            "type": "string",
            "maxLength": 128,
            "description": "Legacy body fallback. Prefer Idempotency-Key request header."
          }
        }
      },
      "AiotCommandResult": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "resultCode": {
            "type": "string"
          },
          "resultPayload": {
            "$ref": "#/components/schemas/JsonValue"
          },
          "resultMediaResourceId": {
            "type": "string"
          },
          "resultObjectBlobId": {
            "type": "string"
          },
          "resultMedia": {
            "$ref": "#/components/schemas/MediaResource"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AiotCommand": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "commandId",
          "deviceId",
          "capabilityName",
          "commandName",
          "requestPayload",
          "status",
          "createdAt"
        ],
        "properties": {
          "commandId": {
            "type": "string"
          },
          "deviceId": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "capabilityName": {
            "type": "string"
          },
          "commandName": {
            "type": "string"
          },
          "requestPayload": {
            "$ref": "#/components/schemas/JsonValue"
          },
          "requestMediaResourceId": {
            "type": "string"
          },
          "requestObjectBlobId": {
            "type": "string"
          },
          "requestMedia": {
            "$ref": "#/components/schemas/MediaResource"
          },
          "status": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          },
          "timeoutAt": {
            "type": "string",
            "format": "date-time"
          },
          "ackAt": {
            "type": "string",
            "format": "date-time"
          },
          "resultAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "result": {
            "$ref": "#/components/schemas/AiotCommandResult"
          }
        }
      },
      "AiotCommandResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/AiotCommand"
          }
        }
      },
      "AiotTwinResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/JsonValue"
          }
        }
      },
      "AiotEvent": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "eventId",
          "eventType",
          "eventVersion",
          "deviceId",
          "protocolId",
          "adapterId",
          "messageClass",
          "semanticType",
          "transport",
          "direction",
          "payload",
          "occurredAt"
        ],
        "properties": {
          "eventId": {
            "type": "string"
          },
          "eventType": {
            "type": "string"
          },
          "eventVersion": {
            "type": "string",
            "maxLength": 16
          },
          "deviceId": {
            "type": "string"
          },
          "protocolId": {
            "type": "string"
          },
          "adapterId": {
            "type": "string"
          },
          "messageClass": {
            "type": "string"
          },
          "semanticType": {
            "type": "string"
          },
          "transport": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": ["device_to_cloud", "cloud_to_device"]
          },
          "messageId": {
            "type": "string"
          },
          "correlationId": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          },
          "payloadHash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 128
          },
          "mediaResourceId": {
            "type": "string"
          },
          "objectBlobId": {
            "type": "string"
          },
          "media": {
            "$ref": "#/components/schemas/MediaResource"
          },
          "payload": {
            "$ref": "#/components/schemas/JsonValue"
          },
          "occurredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AiotEventListResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "data"],
        "properties": {
          "code": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AiotEvent"
            }
          }
        }
      },
      "JsonValue": {
        "description": "Arbitrary JSON value constrained by use-case validation.",
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": true
          },
          {
            "type": "array"
          },
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      },
      "ProblemDetails": {
        "type": "object",
        "additionalProperties": true,
        "required": ["type", "title", "status"],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "detail": {
            "type": "string"
          },
          "traceId": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      }
    }
  }
}
